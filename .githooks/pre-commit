#!/usr/bin/env bash
set -euo pipefail
TS="$(date '+%Y-%m-%dT%H:%M:%S%:z')"
VER="v$(date '+%Y-%m-%d')"
cat > website/version.json <<EOF
{
  "version": "${VER}",
  "updated_at": "${TS}",
  "label": "Atelier live"
}
EOF
cp website/version.json docs/version.json
# stage automatically if present
if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  git add website/version.json docs/version.json >/dev/null 2>&1 || true
fi
